# docker compose env for `kbrd serve` — copy to .env and fill in.

# Web access token (login form), min 12 chars: openssl rand -base64 24
KBRD_TOKEN=

# Fine-grained PAT scoped to the board repo only, contents read/write.
# Referenced by GIT_URL in docker-compose.yml.
GIT_TOKEN=

# Public domain for Let's Encrypt TLS (DNS must point at this host).
# Leave empty to serve plain HTTP on :8080 instead.
KBRD_DOMAIN=
