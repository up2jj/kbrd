{
  "manifest_version": 3,
  "name": "kbrd Capture",
  "version": "0.1.1",
  "description": "Capture the current page or selected text into a local kbrd board.",
  "key": "",
  "permissions": [
    "activeTab",
    "contextMenus",
    "nativeMessaging",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Capture to kbrd",
    "default_popup": "popup.html"
  }
}
